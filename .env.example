# Local Postgres (docker-compose up -d)
DATABASE_URL=postgresql://launchpad:launchpad@localhost:5432/launchpad

# Neon Postgres (production)
# DATABASE_URL=postgresql://user:pass@host.neon.tech/launchpad?sslmode=require

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Resend
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api

# Gumroad
GUMROAD_SELLER_ID=your_seller_id
