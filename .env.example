# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# ─── Auth.js ─────────────────────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://your-domain.com

# Google OAuth (optional — remove Google provider from config if unused)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=/api

# Production domains (comma-separated, for custom domain detection in middleware)
APP_DOMAINS=your-domain.com

# ─── Payments (Gumroad) ─────────────────────────────────────
GUMROAD_SELLER_ID=your_seller_id

# ─── Storage (R2 for production, local for dev) ─────────────
# Set to "r2" for production, omit or "local" for dev
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=your_bucket
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Google Sheets Integration (optional) ────────────────────
# GOOGLE_CLIENT_ID=your-sheets-client-id
# GOOGLE_CLIENT_SECRET=your-sheets-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/integrations/google/callback

# ─── Google Fonts (optional — falls back to 50 popular fonts) ─
# GOOGLE_FONTS_API_KEY=your-api-key
