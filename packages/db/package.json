{
  "name": "@launchpad/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed-plans.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
